        ),
        new(
            Name: "Pavilion Construction (Nigella ERP)",
            Company: "AWK Technologies",
            Description: "An ERP system for Pavilion Construction company (Nigella brand) covering project management, resource allocation, financial tracking, and construction workflow automation.",
