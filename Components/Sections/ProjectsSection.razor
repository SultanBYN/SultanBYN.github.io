@using SultanPortfolio.Web.Components.Shared
@using static SultanPortfolio.Web.Components.Shared.ProjectCard

<SectionPanel Title="Projects" CssClass="projects-section">
    <div class="projects-list">
        @foreach (var project in _projects)
        {
            <ProjectCard Project="@project" />
        }
    </div>
</SectionPanel>

