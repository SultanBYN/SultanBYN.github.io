@using SultanPortfolio.Web.Components.Shared
@using SultanPortfolio.Web.Models
@using SultanPortfolio.Web.Services
@inject INewsFeedService NewsFeedService

<SectionPanel Title="News Feed">
    @if (_isLoading && _articles.Count == 0)
    {
        <div class="news-loading">
            <span class="loading-indicator">Loading articles...</span>
        </div>
    }
    else if (_errorMessage is not null && _articles.Count == 0)
    {
        <div class="news-error">
            <span class="error-message">@_errorMessage</span>
        </div>
    }
    else if (_articles.Count == 0)
    {
        <div class="news-empty">
            <span class="news-empty-title">No articles available right now.</span>
            <span class="news-empty-text">The feed sources are reachable, but they have not returned any items yet.</span>
        </div>
    }
    else
    {
        <div class="news-articles">
            @foreach (var article in _articles)
            {
                <NewsArticleCard Article="@article" />
            }
        </div>

        @if (_errorMessage is not null)
        {
            <div class="news-error-inline">
                <span class="error-message">@_errorMessage</span>
            </div>
        }

        @if (_hasMore)
        {
            <div class="news-load-more">
                <button class="load-more-btn" @onclick="LoadMoreAsync" disabled="@_isLoading">
                    @(_isLoading ? "Loading..." : "Load More")
                </button>
            </div>
        }
    }
</SectionPanel>

@code {
    private List<NewsArticleDto> _articles = [];
    private bool _isLoading = true;
    private string? _errorMessage;
    private int _currentPage = 1;
    private const int PageSize = 20;
    private bool _hasMore = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _isLoading = true;
            var result = await NewsFeedService.GetArticlesAsync(_currentPage, PageSize);
            _articles = result.ToList();
            _hasMore = _articles.Count == PageSize;
        }
        catch (Exception ex)
        {
            _errorMessage = "Unable to load news feed. Please try again later.";
            Console.Error.WriteLine($"[NewsFeedSection] Unexpected error: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadMoreAsync()
    {
        if (_isLoading) return;

        try
        {
            _isLoading = true;
            _currentPage++;
            var result = await NewsFeedService.GetArticlesAsync(_currentPage, PageSize);
            var newArticles = result.ToList();
            _articles.AddRange(newArticles);
            _hasMore = newArticles.Count == PageSize;
        }
        catch (Exception ex)
        {
            _errorMessage = "Unable to load more articles. Please try again later.";
            Console.Error.WriteLine($"[NewsFeedSection] Load more error: {ex.Message}");
            _currentPage--; // Revert page increment on failure
        }
        finally
        {
            _isLoading = false;
        }
    }
}
