@using SultanPortfolio.Web.Components.Shared

<SectionPanel Title="Experience">
    <div class="experience-list">
        @foreach (var position in _positions)
        {
            <div class="work-card">
                <div class="work-card-header">
                    <span class="position-title">@position.Title</span>
                    <span class="position-period">@position.Period</span>
                </div>
                <div class="work-card-meta">
                    <span class="position-company">@position.Company</span>
                    <span class="position-type-badge">@position.EmploymentType</span>
                </div>
                @if (position.AssociatedProjects.Count > 0)
                {
                    <div class="position-projects">
                        <span class="projects-label">Projects:</span>
                        @string.Join(", ", position.AssociatedProjects)
                    </div>
                }
            </div>
        }
    </div>
</SectionPanel>

@code {
    private record WorkPosition(
        string Title,
        string Company,
        string Period,
        string EmploymentType,
        List<string> AssociatedProjects
    );

    private static readonly WorkPosition[] _positions =
    [
